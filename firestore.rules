rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Pairs ──────────────────────────────────────────
    match /pairs/{pairId} {
      // Only paired users can read
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.users
            || request.auth.token.email in resource.data.userEmails);

      // Authenticated users can create a pair (they must be users[0])
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.users[0];

      // Only paired users can update
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.users
            || request.auth.token.email in resource.data.userEmails);

      // ─── Transactions (subcollection) ─────────────────
      match /transactions/{txId} {
        // Only paired users can read
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.users;

        // Any paired user can create a transaction, attributed to either member
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.users
          && request.resource.data.createdBy in get(/databases/$(database)/documents/pairs/$(pairId)).data.users;

        // Any paired user can update status (approve/dispute)
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.users;
      }

      // ─── Balance Snapshots (subcollection) ────────────
      match /balanceSnapshots/{snapId} {
        // Only paired users can read
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.users;

        // Any paired user can create a snapshot
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.users;
      }
    }

    // ─── Invites ────────────────────────────────────────
    match /invites/{inviteId} {
      // Creator can read their sent invites
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toEmail == request.auth.token.email);

      // Any authenticated user can create an invite
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;

      // Recipient can accept (update status)
      allow update: if request.auth != null
        && resource.data.toEmail == request.auth.token.email;
    }
  }
}
