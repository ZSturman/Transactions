# ──────────────────────────────────────────────────────────
# Environment variables (copy to .env.local and fill in)
# ──────────────────────────────────────────────────────────

# Firebase — get these from Firebase Console → Project Settings → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# EmailJS (optional) — sign up at https://www.emailjs.com/ (free tier: 200 emails/month)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_TEMPLATE_TRANSACTION=
NEXT_PUBLIC_EMAILJS_TEMPLATE_RESOLVED=
NEXT_PUBLIC_EMAILJS_TEMPLATE_INVITE=
