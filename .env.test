# Firebase config — fake values are fine; emulators don't validate credentials.
# The project ID must start with "demo-" to use emulators without a real Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-test.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-test
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-test.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:demo000000000000

# Tells firebase.ts to connect to the local emulators instead of production
NEXT_PUBLIC_USE_EMULATORS=true

# Allows Firebase Admin in the Next.js route to use the local emulators.
FIREBASE_ADMIN_PROJECT_ID=demo-test
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
